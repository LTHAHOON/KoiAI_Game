<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Template name="CircleColorPicker" src="project://database/Assets/_KoiAI_Project/Assets/UXML/CircleColorPicker.uxml?fileID=9197481963319205126&amp;guid=2680a82ef5a3bee40ba108c0710ef637&amp;type=3#CircleColorPicker"/>
    <ui:Template name="Scroller" src="project://database/Assets/_KoiAI_Project/Assets/UXML/Scroller.uxml?fileID=9197481963319205126&amp;guid=19d1bdcfd715905409c5f837b270ac9a&amp;type=3#Scroller"/>
    <Style src="project://database/Assets/_KoiAI_Project/Assets/UXML/Global.uss?fileID=7433441132597879392&amp;guid=6ab1825469abf394097e891374d6718e&amp;type=3#Global"/>
    <ui:VisualElement name="root" class="gray-background" style="flex-grow: 1; height: 100%;">
        <ui:VisualElement name="top" style="flex-grow: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px;">
            <ui:Instance template="Scroller" name="character-setting"/>
        </ui:VisualElement>
        <ui:VisualElement name="middle" style="flex-grow: 1;">
            <ui:Instance template="CircleColorPicker" name="TemplateContainer" style="scale: 1 1; position: absolute; align-self: flex-end; right: 0; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px; padding-top: 50px; padding-right: 50px; padding-bottom: 50px; padding-left: 50px;"/>
        </ui:VisualElement>
        <ui:VisualElement name="bottom" style="flex-grow: 0;">
            <ui:VisualElement name="buttons" style="flex-grow: 1; flex-direction: row-reverse;">
                <ui:Button text="취소" name="cancel-button" class="menu-button" style="-unity-font-definition: url(&quot;project://database/Assets/_KoiAI_Project/Assets/Font/TerrarumSansBitmap%20SDF.asset?fileID=11400000&amp;guid=56f1e7dfe73c7a14ca44186c51f1373b&amp;type=2#TerrarumSansBitmap SDF&quot;); width: 20%; height: 40px; font-size: 25px; -unity-font-style: bold; align-self: flex-end; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px;"/>
                <ui:Button text="적용" name="confirm-button" class="menu-button" style="-unity-font-definition: url(&quot;project://database/Assets/_KoiAI_Project/Assets/Font/TerrarumSansBitmap%20SDF.asset?fileID=11400000&amp;guid=56f1e7dfe73c7a14ca44186c51f1373b&amp;type=2#TerrarumSansBitmap SDF&quot;); width: 20%; height: 40px; font-size: 25px; -unity-font-style: bold; align-self: flex-end; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px;"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
