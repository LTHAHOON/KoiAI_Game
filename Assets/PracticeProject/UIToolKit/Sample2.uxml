<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; justify-content: flex-start; flex-direction: column; flex-wrap: nowrap; flex-shrink: 1;">
        <ui:VisualElement name="VisualElement" style="flex-grow: 1; background-color: rgb(255, 12, 0); flex-direction: column; flex-wrap: nowrap; flex-shrink: 1; height: 500px;"/>
        <ui:VisualElement style="flex-grow: 1; background-color: rgb(255, 220, 0); flex-shrink: 1; height: 500px;"/>
        <ui:VisualElement style="flex-grow: 1; background-color: rgb(51, 255, 0); flex-direction: column; height: 500px; flex-shrink: 1;"/>
        <ui:VisualElement style="flex-grow: 1; background-color: rgb(0, 59, 255); align-items: stretch; height: 500px; flex-wrap: nowrap; position: relative; flex-shrink: 1;"/>
    </ui:VisualElement>
</ui:UXML>
